# Field Assist license signing PRIVATE key (base64 Curve25519 raw representation).
#
# Copy this file to `secrets/field-assist-signing-key.txt` (gitignored) and replace the
# placeholder below with the real private key. The key must NEVER be committed or shipped —
# anyone holding it can mint valid Field Assist licenses.
#
# The matching PUBLIC key is embedded in the app at
# `LicenseService.productionPublicKeyBase64` and IS committed (public keys are safe to ship).
#
# Generate a fresh keypair:
#   swift -e 'import CryptoKit; let k = Curve25519.Signing.PrivateKey(); print("private:", k.rawRepresentation.base64EncodedString()); print("public:", k.publicKey.rawRepresentation.base64EncodedString())'
# Put `private` here, and `public` into LicenseService.productionPublicKeyBase64.
#
# Mint a license code (the script reads this file automatically):
#   ./Scripts/generate-field-license.swift "Acme Refrigeration Ltd" [2027-01-01T00:00:00Z]
#
# Lines starting with # are ignored; the key is the first non-comment, non-empty line.
PUT_YOUR_BASE64_PRIVATE_KEY_HERE
